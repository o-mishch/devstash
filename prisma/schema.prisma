generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

// ============================================
// USER
// ============================================
model User {
  id                         String                @id @default(cuid())
  email                      String                @unique
  emailVerified              DateTime?
  // Separate email used for credential (email+password) login, distinct from the OAuth identity
  // `email` above (the default/identity email). When in sync with credentialEmail, both move together
  // on a credential-email change. Verified independently via a confirmation link.
  credentialEmail            String?               @unique
  credentialEmailVerified    DateTime?
  name                       String?
  image                      String?
  password                   String?
  isPro                      Boolean               @default(false)
  proExpiredAt               DateTime?
  stripeCustomerId           String?               @unique
  stripeSubscriptionId       String?               @unique
  stripeSubscriptionStatus   String?
  stripeSubscriptionStart    DateTime?
  stripeCurrentPeriodEnd     DateTime?
  stripeLastSyncAt           DateTime?
  stripeSubscriptionInterval SubscriptionInterval?
  stripeCancelAtPeriodEnd    Boolean               @default(false)
  editorPreferences          Json?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  items        Item[]
  collections  Collection[]
  itemTypes    ItemType[]
  accounts     Account[]
  sessions     Session[]
  aiParseJobs  AiParseJob[]
  aiParseItems AiParseJobItem[]

  @@map("users")
}

// ============================================
// STRIPE WEBHOOK IDEMPOTENCY
// ============================================
enum StripeWebhookEventStatus {
  processing
  processed
}

model StripeWebhookEvent {
  id          String                   @id
  eventType   String
  status      StripeWebhookEventStatus
  createdAt   DateTime                 @default(now())
  processedAt DateTime?

  @@index([status, createdAt])
  @@map("stripe_webhook_events")
}

// ============================================
// NEXTAUTH MODELS
// ============================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  email             String? // OAuth provider email (may differ from User.email)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// @deprecated Auth tokens were migrated to Redis (see `src/lib/auth/tokens.ts`). This table is
/// retained ONLY to satisfy the NextAuth PrismaAdapter contract and is never read or written by
/// application code. Do not use it — any access is logged as a warning by the Prisma client
/// extension in `src/lib/infra/prisma.ts`.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// SUBSCRIPTION
// ============================================
enum SubscriptionInterval {
  month
  year
}

// ITEM
// ============================================
enum ContentType {
  TEXT
  FILE
  URL
}

model Item {
  id          String      @id @default(cuid())
  title       String
  contentType ContentType
  content     String?     @db.Text
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  imageWidth  Int?
  imageHeight Int?
  url         String?
  description String?     @db.Text
  isFavorite  Boolean     @default(false)
  isPinned    Boolean     @default(false)
  language    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemTypeId String
  itemType   ItemType @relation(fields: [itemTypeId], references: [id])
  tags       Tag[]    @relation("ItemTags")

  collections ItemCollection[]
  // Brain Dump parse jobs that reference this item as their source (SetNull on delete).
  parseSources AiParseJob[] @relation("ItemParseSources")

  @@index([itemTypeId])
  @@index([userId, createdAt])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([content(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("items")
}

// ============================================
// ITEM TYPE
// ============================================
model ItemType {
  id       String  @id @default(cuid())
  name     String
  icon     String
  color    String
  isSystem Boolean @default(false)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  Item[]

  defaultForCollections Collection[]

  @@unique([name, userId])
  @@map("item_types")
}

// ============================================
// COLLECTION
// ============================================
model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultTypeId String?
  defaultType   ItemType? @relation(fields: [defaultTypeId], references: [id])

  items ItemCollection[]

  @@index([userId, updatedAt])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("collections")
}

// ============================================
// ITEM-COLLECTION JOIN TABLE
// ============================================
model ItemCollection {
  itemId       String
  collectionId String
  addedAt      DateTime @default(now())

  item       Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([itemId, collectionId])
  @@index([collectionId])
  @@map("item_collections")
}

// ============================================
// TAG
// ============================================
model Tag {
  id    String @id @default(cuid())
  name  String @unique
  items Item[] @relation("ItemTags")

  @@map("tags")
}

// ============================================
// AI FILE SPLITTER — TEMPORARY STAGING TABLES
// ============================================
// One job per "brain dump" upload. `sourceText` holds the raw uploaded file while the AI streams
// drafts; the row (and its items, via cascade) is DELETED on commit. These are draft/staging tables,
// never long-lived storage.
model AiParseJob {
  id         String   @id @default(cuid())
  status     String   @default("processing") // processing | completed | failed | closed
  progress   Int      @default(0) // 0-100 heuristic; determinate once the item count is known
  sourceText String   @db.Text // raw upload; cleared with the row on commit (and on close)
  error      String?
  // v2.5 commit history (status='closed'): denormalized stub stats stamped when the job is committed
  // (every committable draft saved) and merged on each late trash-bucket commit. `committedCount` is
  // the running total of saved items; `committedByType` is the per-type breakdown ({snippet:3,note:2}),
  // null until first close. Purely additive — null/0 for any job that has never closed.
  // `committedCount` is intentionally kept (not derived from `committedByType`) as a cheap queryable
  // scalar — both are written in the same commit/close transaction so they cannot drift.
  committedCount  Int   @default(0)
  committedByType Json?
  // OpenAI background-run handle + replay cursor. The run lives on OpenAI's servers (background mode)
  // so it survives our request ending; `streamCursor` is the last event `sequence_number` we fully
  // processed at a clean line boundary, used as `starting_after` to resume without duplication.
  openaiResponseId String?
  streamCursor     Int?
  // Collection target applied at commit. `collectionName` (seeded from the upload filename, editable)
  // creates a new collection; `collectionIds` attaches to existing collections. Either, both, or
  // neither — committed items join the union of both.
  collectionName String?
  collectionIds  String[] @default([])
  // v1 source persistence: the durable stash Item this job was parsed from (a `note` for paste, a
  // `file` for upload/select), always set at creation. Nullable only so `onDelete: SetNull` fires if
  // the user later deletes the source item (job/drafts survive; re-parse is then disabled).
  // `sourceName` is the display label (note title / file name); `truncated` records that the parse
  // window was boundary-truncated because the source exceeded SPLIT_FILE_MAX_INPUT_CHARS (the stored
  // source item itself is always full).
  sourceItemId String?
  sourceItem   Item?   @relation("ItemParseSources", fields: [sourceItemId], references: [id], onDelete: SetNull)
  sourceName   String?
  truncated    Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  AiParseJobItem[]

  @@index([userId, createdAt])
  @@index([userId, status])
  @@map("ai_parse_jobs")
}

// One draft item produced by the splitter. `itemTypeName` is the BUCKET; dragging a card to another
// bucket updates it before commit. `userId` is denormalized so item-level reads/writes are IDOR-safe
// without a join through the job.
model AiParseJobItem {
  id           String   @id @default(cuid())
  order        Int // generation order; drag updates ordering within a bucket
  itemTypeName String // snippet | prompt | command | note | link | file | image
  title        String
  content      String?  @db.Text
  url          String?
  language     String?
  description  String?  @db.Text
  tags         String[]
  // Soft-delete: a trashed draft moves to the board's Trash bucket instead of being removed. It is
  // excluded from commit and can be restored (trashed=false) or permanently deleted (row removed).
  trashed      Boolean  @default(false)
  createdAt    DateTime @default(now())

  jobId String
  job   AiParseJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([userId])
  @@map("ai_parse_job_items")
}
