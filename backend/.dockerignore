# Keep the build context minimal: only the production Go sources + module files are
# needed (the image builds ./cmd/api). Compiled artifacts, tests, the isolated tool
# modules, and the unrelated learning course bloat the context and bust layer caching.
/api
/tmp/
.git
*.md
.gitignore
.air.toml
.golangci.yml
.taplo.toml
.testcoverage.yml
Taskfile.yml
sqlc.yaml
openapi.json
cover.out
cover.html
# Isolated tool modules (golangci-lint / sqlc / air / govulncheck) — never built into the image.
tools/
golangci-lint/
# Independent Go learning course — not part of the DevStash module.
exercise/
# Test files are not needed to build the binary.
**/*_test.go
