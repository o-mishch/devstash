{
  "name": "devstash",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "openapi:gen": "tsx scripts/generate-openapi.ts && openapi-typescript ./openapi.json -o ./src/types/openapi.ts",
    "themes:gen": "node scripts/generate-themes.js && npm run openapi:gen",
    "themes:fetch": "node scripts/fetch-theme.js && npm run themes:gen",
    "themes:sync": "node scripts/fetch-theme.js --sync && npm run themes:gen",
    "themes:replace": "node scripts/fetch-theme.js --replace && npm run themes:gen",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:format": "prisma format",
    "db:test": "tsx scripts/test-db.ts",
    "stripe:validate-webhooks": "tsx scripts/validate-stripe-webhooks.ts",
    "db:purge-users": "tsx scripts/purge-users.ts",
    "db:purge-demo-items": "tsx scripts/purge-demo-items.ts",
    "test": "vitest watch",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1078.0",
    "@aws-sdk/s3-request-presigner": "^3.1078.0",
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/helpers": "^0.5.0",
    "@dnd-kit/react": "^0.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-neon": "^7.9.0-dev.13",
    "@prisma/client": "^7.9.0-dev.13",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.5",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.23.0",
    "mime-types": "^3.0.2",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.45.0",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "pino": "^10.3.1",
    "react": "19.2.7",
    "react-activity-calendar": "^3.2.0",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.16.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zod-openapi": "^6.0.0",
    "zustand": "^5.0.14"
  },
  "_comment_optionalDependencies": "Self-hosted (GKE/local kind) path ONLY — loaded via runtime-gated require() in db-local.ts / redis-tcp.ts / email-local.ts, externalized in next.config.ts, never reached on Vercel/Neon. Optional so a Vercel `npm ci --omit=optional` can skip them; the container/local build does a full install and gets them.",
  "optionalDependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "google-auth-library": "^10.9.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "rate-limiter-flexible": "^11.2.0",
    "redis": "^6.1.0"
  },
  "overrides": {
    "@auth/prisma-adapter": {
      "@prisma/client": "$@prisma/client"
    },
    "next-auth": {
      "nodemailer": "$nodemailer"
    },
    "esbuild": "^0.28.1",
    "openapi-typescript": {
      "typescript": "$typescript"
    },
    "hono": "^4.12.26",
    "dompurify": "^3.4.11",
    "js-yaml": "^4.2.0",
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@flvmnt/pgfence": "^0.6.1",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^26",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "openapi-typescript": "^7.13.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.9.0-dev.13",
    "raw-loader": "^4.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "prisma": true,
    "@prisma/engines": true,
    "sharp": true,
    "esbuild": true,
    "unrs-resolver": true,
    "fsevents": true
  }
}
