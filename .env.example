# =============================================================================
# DATABASE — Neon PostgreSQL
# Both vars must point to the SAME Neon branch in a given environment.
# Local dev  → Dev branch   |   Production → Production branch
#
# DATABASE_URL  — pooled connection (via Neon connection pooler, used by app)
# DIRECT_URL    — direct connection (bypasses pooler, used by Prisma CLI / migrations / seed)
#
# Find both URLs in Neon dashboard → your project → Connection string
# Toggle "Pooled connection" on/off to get the two variants.
# =============================================================================

DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
