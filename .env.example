# =============================================================================
# DATABASE — Neon PostgreSQL
# Both vars must point to the SAME Neon branch in a given environment.
# Local dev  → Dev branch   |   Production → Production branch
#
# DATABASE_URL  — pooled connection (via Neon connection pooler, used by app)
# DIRECT_URL    — direct connection (bypasses pooler, used by Prisma CLI / migrations / seed)
#
# Find both URLs in Neon dashboard → your project → Connection string
# Toggle "Pooled connection" on/off to get the two variants.
# =============================================================================

DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# =============================================================================
# NEXTAUTH
# =============================================================================

# Random secret used to sign JWTs and session cookies. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Your app's public URL. Required in production for OAuth callbacks and email links.
# Example: https://devstash.one
NEXTAUTH_URL=

# GitHub OAuth app credentials (create at github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth app credentials (create at console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# =============================================================================
# EMAIL — Resend
# =============================================================================

# Resend API key (resend.com → API Keys)
RESEND_API_KEY=

# From address for all outgoing emails. Must use a verified Resend domain.
# Defaults to "DevStash <onboarding@resend.dev>" if not set (Resend test domain, dev only).
EMAIL_FROM=

# =============================================================================
# RATE LIMITING & PRO ACCESS CACHE — Upstash Redis (required in production)
# Create a Redis database at upstash.com and copy the REST URL + token.
# Used for rate limiting and the shared Pro entitlement cache (60s TTL) across
# server instances. Without Redis in production, every cache miss triggers a live
# Stripe subscriptions.retrieve call.
# =============================================================================

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Native TCP Redis/Valkey (node-redis) — leave BLANK on Vercel. Set only on long-running
# deployments (GKE→Memorystore for Valkey, local kind), where it takes precedence over
# the Upstash vars above. REDIS_CA_CERT is the optional PEM to verify Memorystore's
# in-transit TLS (server-authentication) cert. Valkey uses IAM auth (no password in the
# URL), so the URL is host:port only:
#   REDIS_URL=rediss://<host>:6379
# REDIS_IAM_AUTH=true makes the client authenticate with a short-lived Google IAM access
# token (Workload Identity) — set ONLY on GKE. Leave blank locally (plain no-auth valkey).
#
# WARNING: Never set REDIS_URL on Vercel or other serverless runtimes.
# Vercel functions are stateless and cannot hold a persistent TCP connection —
# setting REDIS_URL on Vercel will cause the node-redis client to hang indefinitely
# on connect (no clean error, just a timeout). Use UPSTASH_REDIS_REST_URL instead.
# REDIS_URL is injected automatically by the cluster manifests on GKE and local kind.
REDIS_URL=
REDIS_CA_CERT=
REDIS_IAM_AUTH=

# =============================================================================
# FILE STORAGE — AWS S3
# Create a bucket and an IAM user with AmazonS3FullAccess in the AWS console.
# Generate an access key under IAM → Users → your user → Security credentials.
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# =============================================================================
# SELF-HOSTED PATH (GKE / local kind) — leave ALL blank on Vercel and normal
# `npm run dev`. These are injected by the cluster manifests (ESO on GKE,
# infra/k8s/overlays/local/secret.local.yaml locally), NOT by this file. Listed here
# only to keep the env contract complete. See infra/docs/07-local-run.md.
#
#   DB_DRIVER=pg         select Prisma's node-postgres adapter (real TCP conn →
#                        interactive transactions) instead of the Neon serverless adapter
#   DB_POOL_MAX=5        per-pod node-postgres pool ceiling (maxReplicas * this < Postgres
#                        max_connections); defaults to 5 when unset
#   DATABASE_CA_CERT     Cloud SQL server CA (PEM) — verify the TLS chain (verify-CA;
#                        hostname skipped for the private-IP conn). Unset locally (no TLS)
#   AWS_ENDPOINT_URL_S3  GCS interop (storage.googleapis.com) / MinIO endpoint —
#                        set ⇒ path-style S3; unset ⇒ real AWS S3 virtual-host (Vercel)
#   SMTP_HOST/SMTP_PORT  the local SMTP sink (e.g. mailpit:1025) — set ⇒ send via SMTP
#                        (Mailpit) instead of Resend (GCP/Vercel leave SMTP_HOST unset)
# =============================================================================

DB_DRIVER=
DB_POOL_MAX=
DATABASE_CA_CERT=
AWS_ENDPOINT_URL_S3=
SMTP_HOST=
SMTP_PORT=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Set to "true" to skip Stripe/Redis env validation when Next.js loads next.config
# (local production builds, Docker image builds, CI without full secrets).
# SKIP_ENV_VALIDATION=

# Set to "true" to skip email verification on registration (useful in dev when
# you haven't configured a custom Resend domain yet).
# Omit or leave blank to require email verification (default).
DISABLE_EMAIL_VERIFICATION=

# =============================================================================
# STRIPE — Billing (hosted Checkout; STRIPE_PUBLISHABLE_KEY reserved for future Elements)
# =============================================================================

STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_MONTHLY=""
STRIPE_PRICE_ID_YEARLY=""

# =============================================================================
# AI
# =============================================================================

OPENAI_API_KEY=""

# =============================================================================
# LOGGING
# =============================================================================

# Pino log level: trace | debug | info | warn | error | fatal | silent
# Defaults to "info" when unset.
LOG_LEVEL="info"
