# =============================================================================
# DATABASE — Neon PostgreSQL
# Both vars must point to the SAME Neon branch in a given environment.
# Local dev  → Dev branch   |   Production → Production branch
#
# DATABASE_URL  — pooled connection (via Neon connection pooler, used by app)
# DIRECT_URL    — direct connection (bypasses pooler, used by Prisma CLI / migrations / seed)
#
# Find both URLs in Neon dashboard → your project → Connection string
# Toggle "Pooled connection" on/off to get the two variants.
# =============================================================================

DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# =============================================================================
# NEXTAUTH
# =============================================================================

# Random secret used to sign JWTs and session cookies. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Your app's public URL. Required in production for OAuth callbacks and email links.
# Example: https://devstash.io
NEXTAUTH_URL=

# GitHub OAuth app credentials (create at github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth app credentials (create at console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# =============================================================================
# EMAIL — Resend
# =============================================================================

# Resend API key (resend.com → API Keys)
RESEND_API_KEY=

# From address for all outgoing emails. Must use a verified Resend domain.
# Defaults to "DevStash <onboarding@resend.dev>" if not set (Resend test domain, dev only).
EMAIL_FROM=

# =============================================================================
# RATE LIMITING — Upstash Redis
# Create a Redis database at upstash.com and copy the REST URL + token.
# =============================================================================

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# FILE STORAGE — Filebase
# Create a bucket at filebase.com and copy the S3-compatible key/secret.
# =============================================================================

FILEBASE_KEY=
FILEBASE_SECRET=
FILEBASE_BUCKET=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Set to "true" to skip email verification on registration (useful in dev when
# you haven't configured a custom Resend domain yet).
# Omit or leave blank to require email verification (default).
DISABLE_EMAIL_VERIFICATION=

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_MONTHLY=""
STIPE_PRICE_ID_YEARLY=""
