# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored — never commit real
# values for a real environment.
#
# NOTE: dev and prod share ONE GCP project (project-39965ce5-4c4b-495e-8d4) — prod is a second
# environment, not a second project. This env deliberately does NOT recreate dev-owned shared
# resources (the github-actions WIF pool); it references them. And it uses its OWN Artifact
# Registry repo (devstash-prod) so dev's suspend/resume never touches prod's images.

project_id = "project-39965ce5-4c4b-495e-8d4"
# gcloud projects describe project-39965ce5-4c4b-495e-8d4 --format='value(projectNumber)'
project_number = "000000000000"

region            = "us-central1"
environment       = "prod"
github_repository = "o-mishch/devstash"

app_domain             = "api.devstash.one"
firebase_custom_domain = "beta.devstash.one"

# --- Cloud Build trigger (classic GitHub-App integration — no 2nd-gen connection exists in
# this project, confirmed via `gcloud builds connections list --region=global` returning
# empty) --- cloudbuild_trigger_name already defaults to the live trigger's real, immutable,
# auto-generated name; override only if that ever changes.
# cloudbuild_trigger_name = "rmgpgab-devstash-europe-southwest1-o-mishch-devstash--featurmjg"

# cloudbuild_branch_filter defaults to the live trigger's real filter
# (^feature/go-backend-vite-spa$) — the rewrite ships on the feature branch for the whole
# strangler period (main stays on Vercel). Deliberately NOT switched to ^main$. Override only
# if that integration branch is ever renamed.
# cloudbuild_branch_filter = "^feature/go-backend-vite-spa$"

# --- Backend secrets (app_config) ---
# ALL sensitive backend env vars, JSON-encoded into ONE secret (devstash-prod-config) so the app
# needs a single Secret Manager version ($0). Keys are env-var NAMES; config.go splits them back
# into env vars at boot. Write-only (secret_data_wo) — never stored in Terraform state, but they
# DO live here in plaintext (gitignored). Non-secret vars (ENV/ALLOWED_ORIGINS/NEXT_PUBLIC_APP_URL/
# EMAIL_FROM) are plain defaults in variables.tf, not here.
app_config = {
  DATABASE_URL       = "postgres://…" # Neon prod
  REDIS_URL          = "rediss://…@…upstash.io:6379"
  AUTH_SECRET        = "…"
  AUTH_GITHUB_ID     = "…" # OAuth client id (public, but grouped here for one secret)
  AUTH_GITHUB_SECRET = "…"
  AUTH_GOOGLE_ID     = "…"
  AUTH_GOOGLE_SECRET = "GOCSPX-…"
  RESEND_API_KEY     = "re_…"
}
