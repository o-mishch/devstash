# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored — never
# commit real project IDs / values for a real environment.
project_id  = "my-devstash-project"
# GCS Always Free applies specifically to us-central1/us-east1/us-west1 (aggregate
# 5 GB-months), not every US region or the "US" multi-region. Must match the
# hard-coded REGION in deploy-gke.yml.
region      = "us-central1"
environment = "dev"

# Keyless CI: GitHub repo allowed to federate (Workload Identity), "owner/repo".
github_repository = "my-org/devstash"
# Numeric owner ID — immutable, pins the WIF condition. Get it from:
#   curl -s https://api.github.com/users/my-org | jq .id
github_owner_id = "000000"

# Public hostname for the GKE deploy. DNS A-record must point at the Ingress
# static IP after apply (tofu output ingress_ip_address). Drives the managed
# cert + NEXTAUTH_URL.
# Use a SUBDOMAIN — the apex (devstash.one) + www serve production on Vercel,
# so the self-managed GKE deploy lives on its own hostname to avoid a collision.
app_domain = "gke.devstash.one"

# Real 3rd-party credentials Terraform can't derive (Stripe, Resend, OAuth,
# OpenAI). kebab-case key K -> Secret Manager secret `devstash-K`, granted to the
# app SA, consumed by the ESO ExternalSecret. See 08-gcp-bootstrap.md §7b. Fill in
# real values in terraform.tfvars (gitignored) — these are placeholders only.
# NOTE: database-url / direct-url are NOT here — they target the managed Cloud SQL
# private IP and are generated by Terraform (random_password + module.cloudsql) in
# main.tf. redis-url / redis-ca-cert are likewise derived from module.memorystore
# (rediss:// + server CA — Memorystore in-transit TLS).
# Non-secret sender identity — drives EMAIL_FROM in the devstash-config ConfigMap
# (infra/k8s/overlays/gcp/kustomization.yaml). Must be a verified sender domain in Resend.
email_from = "DevStash <noreply@devstash.one>"

third_party_secrets = {
  "auth-secret"              = "openssl rand -base64 32"
  "auth-github-id"           = "Ov..."
  "auth-github-secret"       = "..."
  "auth-google-id"           = "....apps.googleusercontent.com"
  "auth-google-secret"       = "GOCSPX-..."
  "resend-api-key"           = "re_..."
  # "email-from" is NOT here — it is a non-secret constant set in the ConfigMap
  # (infra/k8s/overlays/gcp/kustomization.yaml → EMAIL_FROM), not Secret Manager.
  "stripe-secret-key"        = "sk_..."
  "stripe-publishable-key"   = "pk_..."
  "stripe-webhook-secret"    = "whsec_..."
  "stripe-price-id-monthly"  = "price_..."
  "stripe-price-id-yearly"   = "price_..."
  "openai-api-key"           = "sk-..."
}

# Cloud SQL machine tier (default db-f1-micro — cheapest shared-core for dev).
# db_tier = "db-f1-micro"

# Cloud SQL high availability — enables a standby replica in a second zone.
# Doubles the hourly cost of the SQL instance but provides automatic failover
# (< 60 s) if the primary zone fails. Recommended for production; off by default
# for the $300-trial dev environment where cost matters more than HA.
# db_highly_available = true

# Memorystore high availability — enables a replica node (STANDARD_HA tier).
# Without it, a Memorystore instance is BASIC (single node, no replica). For
# session data that must survive a node failure, enable this.
# memory_highly_available = true

# Cloud Armor preconfigured SQLi/XSS rules start in preview so editor/code payloads
# can be checked for false positives in load-balancer logs. Set false only after that
# observation period; doing so changes the same rules from log-only to enforced 403s.
# armor_waf_preview = false

# Destructive two-phase guard. Keep true normally. For intentional teardown, set
# false in the gitignored terraform.tfvars, run `run.sh apply` and review that only
# protection changes, then run `run.sh down`. Never edit reusable module source.
# deletion_protection = false

# IP allowlist for DIRECT developer access to the Cloud SQL PUBLIC IP (psql/GUI).
# Empty by default; add your laptop's public IP (find it: curl ifconfig.me). SSL
# is always required. After apply, get the connection string:
#   tofu output -raw db_public_database_url
# db_authorized_networks = [
#   { name = "home", value = "203.0.113.4/32" },
# ]
