# Pinned versions for Helm charts installed on the GKE cluster.
# Sourced by both infra/run/gcp/run.sh and .github/workflows/deploy-gke.yml
# so the bootstrap script and CI always install the same versions.
#
# HOW TO UPGRADE:
#   1. Check latest ESO:      helm search repo external-secrets/external-secrets --versions | head -5
#   2. Check latest Reloader: helm search repo stakater/reloader --versions | head -5
#   3. Read the release notes for breaking changes before bumping.
#   4. Update both values below.
#   5. Re-run:  bash infra/run/gcp/run.sh eso
#      (runs `helm upgrade --install` with the new version on the live cluster)
#
# ESO CRD apiVersion compatibility:
#   ESO >= 0.10.x ships external-secrets.io/v1 CRDs (GA). The manifests in
#   infra/k8s/overlays/gcp/external-secrets.yaml use apiVersion: external-secrets.io/v1
#   which is compatible with all ESO versions >= 0.10.x.
#   DO NOT downgrade below 0.10.0 — that would revert CRDs to v1beta1 and break the overlay.
#   The ESO project moved to 2.x versioning (both chart and operator) in 2025.
#   The chart is published as `helm-chart-2.x.y` on GitHub releases; the Helm chart
#   version used in `helm upgrade --install --version` is `2.x.y` (e.g. 2.5.0).
#   apiVersion: external-secrets.io/v1 and workloadIdentity auth are unchanged in 2.x.
#
# Reloader compatibility:
#   Reloader >= 1.0.0 uses the same annotation format:
#   secret.reloader.stakater.com/reload: "devstash-secrets" (set in base/deployment.yaml).
#   Chart 2.x (chart-v2.x.y) maps to operator 1.x; annotation format is unchanged.
#   No annotation change needed when upgrading from 1.x to 2.x chart series.
# Verified against the upstream Helm release list. Do not invent a version from the
# operator/app sequence: a nonexistent chart makes every deployment fail before apply.
ESO_VERSION=2.7.0
# Reloader chart-v2.x.y tag on GitHub → Helm chart version 2.x.y (used with --version).
# Latest chart (chart-v2.2.14) packages operator v1.4.19.
RELOADER_VERSION=2.2.14
