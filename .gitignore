# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# prisma generated client
/src/generated

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
tmp

# local editor config
.vscode/

# db session files
*.session.sql

.playwright-mcp

# UI-snapshot / motion-capture harness (throwaway: screenshots, videos, session state)
/capture/

# local MCP config (may contain API keys)
.mcp.json
.cursor/mcp.json

*.png
# ...except committed static assets the web build/deploy needs (e.g. the social OG card).
!web/public/*.png
.idea

.projects/cache
.projects/vault
.projects/state.test.json
.projects/state.local.test.json
.env
.env.*
!.env.example
*.mov
*.jpeg

# Terraform — never commit real values or state (may contain plaintext secrets)
*.tfvars
!*.tfvars.example
*.tfstate
*.tfstate.*
*.tfplan
.terraform/
# .terraform.lock.hcl is intentionally tracked — it pins provider versions so
# `tofu init` on any machine or CI run produces the same providers. Only the
# .terraform/ working directory (downloaded plugins) is excluded.
# kind kubeconfig written by local cluster provisioning — contains a live client cert/key
infra/terraform/envs/local/devstash-config
**.obsidian

# Go workspace files — the backend tools (air/sqlc/golangci-lint) run via `go tool
# -modfile=…`, which is incompatible with workspace mode. gopls may auto-create a
# go.work when it sees the nested tool modules; never commit it (it breaks tooling).
go.work
go.work.sum
.ruff_cache
.pytest_cache
.mypy_cache
# cleanup skill (improve mode) — local-only working state.
# The findings ledger is a CACHE for classifying findings new/known/fixed across
# runs; the codebase is always the source of truth and the audit re-derives every
# finding from it. Never committed: a stale ledger must never look authoritative.
context/cleanup-findings.md
.cleanup-args.json
.cleanup-plan.json
.cleanup-structure.json
.cleanup-changeset.txt
.cleanup-groups/
