# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# prisma generated client
/src/generated

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
tmp

# local editor config
.vscode/

# db session files
*.session.sql

.playwright-mcp

# local MCP config (may contain API keys)
.mcp.json
.cursor/mcp.json

*.png
.idea

.projects/cache
.projects/vault
.projects/state.test.json
.projects/state.local.test.json
.env
.env.*
!.env.example
*.mov
*.jpeg

# Terraform — never commit real values or state (may contain plaintext secrets)
*.tfvars
!*.tfvars.example
*.tfstate
*.tfstate.*
*.tfplan
.terraform/
# .terraform.lock.hcl is intentionally tracked — it pins provider versions so
# `tofu init` on any machine or CI run produces the same providers. Only the
# .terraform/ working directory (downloaded plugins) is excluded.
**.obsidian
