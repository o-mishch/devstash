{
  "name": "devstash-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc -p tsconfig.scripts.json && tsx scripts/gen-og-image.tsx && vite build && tsx scripts/finalize-dist.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "lint": "oxlint .",
    "format": "oxfmt --write 'src/**/*.{ts,tsx}'",
    "format:check": "oxfmt --check 'src/**/*.{ts,tsx}'",
    "openapi:gen": "openapi-ts",
    "themes:fetch": "tsx scripts/fetch-theme.ts",
    "themes:gen": "tsx scripts/generate-themes.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@fontsource-variable/geist": "^5.2.9",
    "@hey-api/client-fetch": "0.13.1",
    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/react-start": "1.168.28",
    "@tanstack/react-virtual": "^3.14.6",
    "@uiw/codemirror-theme-github": "^4.25.11",
    "@uiw/react-codemirror": "^4.25.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "mini-svg-data-uri": "^1.4.4",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-activity-calendar": "^3.2.1",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hey-api/openapi-ts": "0.99.0",
    "@resvg/resvg-js": "^2.6.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "csp-header": "^6.3.1",
    "node-html-parser": "^9.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-sitemap": "^0.8.2",
    "vite-plugin-svgr": "^5.2.0"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": true
  }
}
